# Tradelah - Environment Configuration

# Questrade API Secrets
QUESTRADE_API_URL=https://api01.questrade.com
QUESTRADE_REFRESH_TOKEN=your_questrade_refresh_token_here

# Notification Settings (Telegram Bot Example)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Simulation Mode (true = use mock data and log notifications to console instead of sending actual calls)
SIMULATION_MODE=true
